{
  "emulators": {
    "storage.googleapis.com": {
      "name": "minisky-gcs",
      "image": "fsouza/fake-gcs-server:latest",
      "port": "4443/tcp",
      "cmd": ["-scheme", "http"]
    },
    "pubsub.googleapis.com": {
      "name": "minisky-pubsub",
      "image": "gcr.io/google.com/cloudsdktool/cloud-sdk:emulators",
      "port": "8085/tcp",
      "cmd": ["gcloud", "beta", "emulators", "pubsub", "start", "--host-port=0.0.0.0:8085"]
    },
    "firestore.googleapis.com": {
      "name": "minisky-firestore",
      "image": "gcr.io/google.com/cloudsdktool/cloud-sdk:emulators",
      "port": "8082/tcp",
      "cmd": ["gcloud", "beta", "emulators", "firestore", "start", "--host-port=0.0.0.0:8082"]
    },
    "bigtable.googleapis.com": {
      "name": "minisky-bigtable",
      "image": "google/cloud-sdk:latest",
      "port": "8086/tcp",
      "cmd": ["gcloud", "beta", "emulators", "bigtable", "start", "--host-port=0.0.0.0:8086"]
    },
    "datastore.googleapis.com": {
      "name": "minisky-datastore",
      "image": "gcr.io/google.com/cloudsdktool/cloud-sdk:emulators",
      "port": "8081/tcp",
      "cmd": ["gcloud", "beta", "emulators", "datastore", "start", "--host-port=0.0.0.0:8081", "--data-dir=/data", "--project=minisky-project"],
      "volume": "./data/datastore:/data"
    },
    "spanner.googleapis.com": {
      "name": "minisky-spanner",
      "image": "gcr.io/cloud-spanner-emulator/emulator",
      "port": "9020/tcp",
      "cmd": []
    },
    "identitytoolkit.googleapis.com": {
      "name": "minisky-firebase-auth",
      "image": "andreysenov/firebase-tools:latest",
      "port": "9099/tcp",
      "cmd": ["sh", "-c", "printf '{\"emulators\":{\"hub\":{\"host\":\"0.0.0.0\",\"port\":4400},\"auth\":{\"host\":\"0.0.0.0\",\"port\":9099},\"database\":{\"host\":\"0.0.0.0\",\"port\":9000},\"hosting\":{\"host\":\"0.0.0.0\",\"port\":5000},\"ui\":{\"enabled\":false}}}' > firebase.json && firebase emulators:start --only auth --project minisky-project"],
      "volume": "",
      "env": [
        "FIREBASE_AUTH_EMULATOR_HOST=0.0.0.0:9099",
        "PUBSUB_EMULATOR_HOST=172.17.0.1:8080",
        "FIRESTORE_EMULATOR_HOST=172.17.0.1:8080",
        "GOOGLE_CLOUD_PROJECT=minisky-project"
      ]
    },
    "firebaseio.com": {
      "name": "minisky-firebase-rtdb",
      "image": "andreysenov/firebase-tools:latest",
      "port": "9000/tcp",
      "cmd": ["sh", "-c", "printf '{\"emulators\":{\"hub\":{\"host\":\"0.0.0.0\",\"port\":4400},\"auth\":{\"host\":\"0.0.0.0\",\"port\":9099},\"database\":{\"host\":\"0.0.0.0\",\"port\":9000},\"hosting\":{\"host\":\"0.0.0.0\",\"port\":5000},\"ui\":{\"enabled\":false}}}' > firebase.json && firebase emulators:start --only database --project minisky-project"],
      "volume": "",
      "env": [
        "FIREBASE_DATABASE_EMULATOR_HOST=0.0.0.0:9000",
        "FIREBASE_AUTH_EMULATOR_HOST=172.17.0.1:8080",
        "GOOGLE_CLOUD_PROJECT=minisky-project"
      ]
    },
    "firebasehosting.googleapis.com": {
      "name": "minisky-firebase-hosting",
      "image": "andreysenov/firebase-tools:latest",
      "port": "5000/tcp",
      "cmd": ["sh", "-c", "printf '{\"emulators\":{\"hub\":{\"host\":\"0.0.0.0\",\"port\":4400},\"auth\":{\"host\":\"0.0.0.0\",\"port\":9099},\"database\":{\"host\":\"0.0.0.0\",\"port\":9000},\"hosting\":{\"host\":\"0.0.0.0\",\"port\":5000},\"ui\":{\"enabled\":false}}}' > firebase.json && firebase emulators:start --only hosting --project minisky-project"],
      "volume": "",
      "env": [
        "FIREBASE_HOSTING_EMULATOR_HOST=0.0.0.0:5000",
        "GOOGLE_CLOUD_PROJECT=minisky-project"
      ]
    },
    "cloudkms.googleapis.com": {
      "name": "minisky-kms",
      "image": "winor30/fake-cloud-kms:latest",
      "port": "9010/tcp",
      "cmd": []
    }
  },
  "compute": {
    "os_images": [
      { "id": "ubuntu-2604-lts", "label": "Ubuntu 26.04 LTS", "image": "ubuntu:26.04" },
      { "id": "ubuntu-2404-lts", "label": "Ubuntu 24.04 LTS", "image": "ubuntu:24.04" },
      { "id": "ubuntu-2204-lts", "label": "Ubuntu 22.04 LTS", "image": "ubuntu:22.04" },
      { "id": "debian-12", "label": "Debian 12 Bookworm", "image": "debian:12" },
      { "id": "rocky-9", "label": "Rocky Linux 9", "image": "rockylinux:9" }
    ],
    "default_image": "ubuntu:26.04"
  },
  "sql": {
    "postgres": {
      "latest": "18.3",
      "versions": [
        { "version": "18", "label": "PostgreSQL 18 (Latest)", "image": "postgres:18.3-alpine" },
        { "version": "17", "label": "PostgreSQL 17", "image": "postgres:17.9-alpine" },
        { "version": "16", "label": "PostgreSQL 16", "image": "postgres:16.13-alpine" }
      ],
      "default_image": "postgres:18.3-alpine"
    },
    "mysql": {
      "latest": "8.4",
      "versions": [
        { "version": "9.0", "label": "MySQL 9.0 Innovation", "image": "mysql:9.0" },
        { "version": "8.4", "label": "MySQL 8.4 LTS", "image": "mysql:8.4" },
        { "version": "8.0", "label": "MySQL 8.0 (Legacy)", "image": "mysql:8.0" }
      ],
      "default_image": "mysql:8.4"
    }
  },
  "serverless": {
    "builder": "gcr.io/buildpacks/builder:google-24"
  },
  "dataproc": {
    "latest": "4.0",
    "versions": [
      { "version": "4.0", "label": "Spark 4.0 (Latest)", "image": "bitnami/spark:4.0" },
      { "version": "3.5", "label": "Spark 3.5", "image": "bitnami/spark:3.5" },
      { "version": "3.4", "label": "Spark 3.4", "image": "bitnami/spark:3.4" }
    ],
    "default_image": "bitnami/spark:4.0",
    "master_ports": ["8080/tcp"]
  },
  "memorystore": {
    "redis": {
      "default_image": "redis:8.0-alpine",
      "versions": [
        { "version": "8.0", "label": "Redis 8.0 (Latest)", "image": "redis:8.0-alpine" },
        { "version": "7.4", "label": "Redis 7.4", "image": "redis:7.4-alpine" },
        { "version": "7.2", "label": "Redis 7.2 (LTS)", "image": "redis:7.2-alpine" }
      ]
    },
    "memcached": {
      "default_image": "memcached:1.6.33-alpine",
      "versions": [
        { "version": "1.6.33", "label": "Memcached 1.6.33 (Latest)", "image": "memcached:1.6.33-alpine" },
        { "version": "1.6.32", "label": "Memcached 1.6.32", "image": "memcached:1.6.32-alpine" },
        { "version": "1.5.22", "label": "Memcached 1.5.22 (Legacy)", "image": "memcached:1.5.22-alpine" }
      ]
    },
    "valkey": {
      "default_image": "valkey/valkey:9.0.3-alpine",
      "versions": [
        { "version": "9.0", "label": "Valkey 9.0 (Latest)", "image": "valkey/valkey:9.0.3-alpine" },
        { "version": "8.1", "label": "Valkey 8.1", "image": "valkey/valkey:8.1.6-alpine" },
        { "version": "7.2", "label": "Valkey 7.2", "image": "valkey/valkey:7.2.12-alpine" }
      ]
    }
  },
  "cloudbuild": {
    "default_builder": "ubuntu:26.04"
  },
  "artifact_registry": {
    "image": "registry:2",
    "port": "5000/tcp",
    "domain": "artifactregistry.googleapis.com"
  },
  "vertex_ai": {
    "image": "ollama/ollama:latest",
    "port": "11434/tcp",
    "domain": "aiplatform.googleapis.com"
  }
}
